# ENV EXAMPLE — MARTEC CORE OPS

APP_NAME=martec-core
ENVIRONMENT=prod
HOSTNAME_TAG=martec-core-01

# PostgreSQL
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=martec_core
PGUSER=postgres
PGPASSWORD=CHANGE_ME

# Paths
BACKUP_ROOT=/opt/backups/martec-core
FILES_SOURCE_DIR=/srv/martec-core/files
QDRANT_STORAGE_DIR=/var/lib/qdrant/storage

# Remote
REMOTE_BACKUP_NAME=remote:martec-core

# Restic
RESTIC_REPOSITORY=rclone:remote:martec-core-restic
RESTIC_PASSWORD=CHANGE_ME
